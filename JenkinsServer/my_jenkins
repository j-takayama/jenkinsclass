# -----------------------------------------------------------------------------
# File: JenkinsServer/my-jenkins
# Purpose: Build a custom Jenkins image with:
# - Corporate root CA trust configured for OS + Java
# - Common tooling (curl, git, openssl)
# - Jenkins user added to the docker group
# - Docker plugin preinstalled
#
# Build context requirement:
# - `MITRE_BA_ROOT.crt` must be present in the same build context directory.
#
# Typical usage:
# - Build: docker build -f JenkinsServer/my-jenkins -t custom-jenkins .
# - Run:   docker run -p 8080:8080 -p 50000:50000 custom-jenkins
# -----------------------------------------------------------------------------

# Use the official Jenkins image as the base.
FROM jenkins/jenkins:latest

# Switch to root for package installation and system-level certificate updates.
USER root

# Add the corporate root certificate to the Linux trust store location.
COPY MITRE_BA_ROOT.crt /usr/local/share/ca-certificates/corp-root-ca.crt

# Install required packages, refresh trust store, and import the same certificate
# into the JVM cacerts keystore so Java-based Jenkins plugins trust internal TLS.
RUN apt-get update && apt-get install -y ca-certificates openssl  curl git\
 && update-ca-certificates \
 && keytool -importcert -noprompt -trustcacerts \
      -alias corp-root-ca \
      -file /usr/local/share/ca-certificates/corp-root-ca.crt \
      -keystore "$JAVA_HOME/lib/security/cacerts" \
      -storepass changeit

# Ensure the `jenkins` user can access the Docker socket when mounted from host.
RUN groupadd -f docker && usermod -aG docker jenkins

# Keep image size smaller by cleaning apt metadata.
RUN rm -rf /var/lib/apt/lists/*

# Persist Jenkins configuration, plugins, and jobs.
VOLUME /var/jenkins_home

# Expose Jenkins web UI and inbound agent port.
EXPOSE 8080 50000

# Run Jenkins as non-root for normal operation.
USER jenkins

# Preinstall Docker plugin at image build time for faster first boot.
RUN jenkins-plugin-cli --plugins docker-plugin

# Jenkins entrypoint is already defined in the base image
# So we just inherit it; no CMD or ENTRYPOINT needed.
